<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_main"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Добавить ответ"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="24dp" />

    <!-- Вопрос -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        android:elevation="0dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_command"
            android:tint="@color/violet_primary"
            android:layout_marginEnd="12dp" />

        <EditText
            android:id="@+id/et_question"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Вопрос"
            android:textColorHint="@color/text_low"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="1"
            android:maxLines="4"
            android:padding="0dp" />
    </LinearLayout>

    <!-- Ответ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:padding="16dp"
        android:gravity="top"
        android:layout_marginBottom="8dp"
        android:elevation="0dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_log"
            android:tint="@color/violet_primary"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp" />

        <EditText
            android:id="@+id/et_answer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Ответ"
            android:textColorHint="@color/text_low"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:inputType="textMultiLine|textCapSentences|textUri"
            android:minLines="2"
            android:maxLines="8"
            android:maxLength="500"
            android:padding="0dp"
            android:autoLink="web" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Можно оставить пустым, если добавляешь только вложения"
        android:textColor="@color/text_low"
        android:textSize="12sp"
        android:paddingStart="40dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Счетчик символов -->
    <TextView
        android:id="@+id/tv_char_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0/500"
        android:textColor="@color/text_low"
        android:textSize="12sp"
        android:gravity="end"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp" />

    <!-- VK Вложения -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:padding="16dp"
        android:gravity="top"
        android:layout_marginBottom="8dp"
        android:elevation="0dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_swipe"
            android:tint="@color/violet_primary"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp" />

        <EditText
            android:id="@+id/et_attachments"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="VK вложения"
            android:textColorHint="@color/text_low"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:inputType="textMultiLine|textUri"
            android:minLines="1"
            android:maxLines="4"
            android:padding="0dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Вставь ссылку на фото, видео, клип из VK"
        android:textColor="@color/text_low"
        android:textSize="12sp"
        android:paddingStart="40dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="32dp" />

    <!-- Кнопки -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Отмена"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:minWidth="100dp"
            android:layout_marginEnd="12dp"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Сохранить"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:backgroundTint="@color/violet_primary"
            app:cornerRadius="12dp"
            android:minWidth="140dp" />
    </LinearLayout>

</LinearLayout>
