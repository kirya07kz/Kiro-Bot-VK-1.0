<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- Индикаторы страниц -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/bg_card"
        app:tabTextColor="@color/text_medium"
        app:tabSelectedTextColor="@color/violet_primary"
        app:tabIndicatorColor="@color/violet_primary"
        app:tabIndicatorHeight="2dp"
        app:tabTextAppearance="@style/TabTextStyle"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabPaddingTop="2dp"
        app:tabPaddingBottom="2dp" />

    <!-- ViewPager для свайпа между экранами -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>