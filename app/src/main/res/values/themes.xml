<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dracula Theme Colors -->
    <style name="Theme.VKBotManager" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">#8BE9FD</item>
        <item name="colorOnPrimary">#282a36</item>
        <item name="colorPrimaryVariant">#50FA7B</item>
        
        <!-- Secondary colors -->
        <item name="colorSecondary">#FFB86C</item>
        <item name="colorOnSecondary">#282a36</item>
        <item name="colorSecondaryVariant">#BD93F9</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">#282a36</item>
        <item name="colorOnBackground">#F8F8F2</item>
        
        <!-- Surface colors -->
        <item name="colorSurface">#44475a</item>
        <item name="colorOnSurface">#F8F8F2</item>
        <item name="colorSurfaceVariant">#6272a4</item>
        <item name="colorOnSurfaceVariant">#F8F8F2</item>
        
        <!-- Error colors -->
        <item name="colorError">#FF5555</item>
        <item name="colorOnError">#F8F8F2</item>
        
        <!-- System bars -->
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/black</item>
        <item name="android:navigationBarColor">@color/bg_main</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">false</item>
        
        <!-- Material components -->
        <item name="colorControlNormal">#6272a4</item>
        <item name="colorControlActivated">#8BE9FD</item>
        <item name="colorControlHighlight">#50FA7B</item>
    </style>

    <style name="TabLayoutStyle" parent="Widget.Material3.TabLayout">
        <item name="tabTextColor">#6272a4</item>
        <item name="tabSelectedTextColor">#F8F8F2</item>
        <item name="tabIndicatorColor">#8BE9FD</item>
        <item name="android:background">#44475a</item>
        <item name="tabRippleColor">#50FA7B</item>
    </style>

    <!-- Custom MaterialButton style for consistent theming -->
    <style name="Widget.VKBot.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">#282a36</item>
        <item name="backgroundTint">#50FA7B</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:elevation">8dp</item>
        <item name="rippleColor">#8BE9FD</item>
    </style>

    <style name="Widget.VKBot.Button.Secondary" parent="Widget.VKBot.Button">
        <item name="backgroundTint">#FFB86C</item>
        <item name="android:textColor">#282a36</item>
    </style>

    <style name="Widget.VKBot.Button.Danger" parent="Widget.VKBot.Button">
        <item name="backgroundTint">#FF5555</item>
        <item name="android:textColor">#F8F8F2</item>
    </style>

    <!-- TextInputLayout style -->
    <style name="Widget.VKBot.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#6272a4</item>
        <item name="boxStrokeColor">#8BE9FD</item>
        <item name="hintTextColor">#F8F8F2</item>
        <item name="android:textColorHint">#BD93F9</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- TabLayout text style -->
    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">9sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">normal</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
    </style>
</resources>